<Ui xmlns="http://www.blizzard.com/wow/ui/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">

    <!-- BarWardenBarTemplate: A single tracking bar (StatusBar with icon, text overlays, spark, background) -->
    <StatusBar name="BarWardenBarTemplate" virtual="true" minValue="0" maxValue="1" defaultValue="0">
        <Size x="200" y="20"/>
        <Layers>
            <!-- Background layer -->
            <Layer level="BACKGROUND">
                <Texture name="$parentBackground" setAllPoints="true">
                    <Color r="0" g="0" b="0" a="0.6"/>
                </Texture>
            </Layer>
            <!-- Border layer -->
            <Layer level="BORDER">
                <Texture name="$parentBorder" setAllPoints="true">
                    <Color r="0" g="0" b="0" a="0.8"/>
                </Texture>
            </Layer>
            <!-- NameText, TimeText, and Spark are created programmatically in Bar.lua -->
            <!-- FontStrings in StatusBar <Layer> blocks are not globally registered in 3.3.5a -->
        </Layers>
        <Frames>
            <!-- Icon frame on the left -->
            <Frame name="$parentIcon">
                <Size x="20" y="20"/>
                <Anchors>
                    <Anchor point="LEFT" x="1" y="0"/>
                </Anchors>
                <Layers>
                    <Layer level="ARTWORK">
                        <Texture name="$parentIconTexture" setAllPoints="true"/>
                    </Layer>
                </Layers>
            </Frame>
        </Frames>
    </StatusBar>

    <!-- BarWardenGroupTemplate: Container frame for a group of bars with backdrop -->
    <Frame name="BarWardenGroupTemplate" virtual="true" enableMouse="true" movable="true" clampedToScreen="true">
        <Size x="210" y="100"/>
        <Backdrop bgFile="Interface\Tooltips\UI-Tooltip-Background" edgeFile="Interface\Tooltips\UI-Tooltip-Border" tile="true">
            <EdgeSize val="12"/>
            <TileSize val="16"/>
            <BackgroundInsets left="2" right="2" top="2" bottom="2"/>
        </Backdrop>
        <Layers>
            <Layer level="OVERLAY">
                <FontString name="$parentTitle" inherits="GameFontNormal" justifyH="CENTER">
                    <Anchors>
                        <Anchor point="TOP" x="0" y="-4"/>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
    </Frame>

    <!-- BarWardenTabButtonTemplate: Tab button for the config panel -->
    <Button name="BarWardenTabButtonTemplate" inherits="CharacterFrameTabButtonTemplate" virtual="true">
        <Size x="0" y="32"/>
    </Button>

</Ui>
